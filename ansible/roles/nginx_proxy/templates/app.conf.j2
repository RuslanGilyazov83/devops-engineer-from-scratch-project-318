# Формат JSON для structured logging — удобно парсить в Loki/ELK
log_format json_combined escape=json
  '{'
    '"time":"$time_iso8601",'
    '"remote_addr":"$remote_addr",'
    '"method":"$request_method",'
    '"uri":"$request_uri",'
    '"status":$status,'
    '"body_bytes_sent":$body_bytes_sent,'
    '"request_time":$request_time,'
    '"upstream_response_time":"$upstream_response_time",'
    '"http_referer":"$http_referer",'
    '"http_user_agent":"$http_user_agent"'
  '}';

server {
    listen 80;
    server_name _;

    access_log /var/log/nginx/app-access.log json_combined;
    error_log  /var/log/nginx/app-error.log warn;

    # Основное приложение
    location / {
        proxy_pass         http://127.0.0.1:{{ app_port }};
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    # Проброс actuator endpoints с management-порта
    location /actuator/ {
        proxy_pass         http://127.0.0.1:{{ app_management_port }}/actuator/;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_read_timeout 30s;
    }

    # stub_status для nginx-prometheus-exporter — доступ только localhost и сервер мониторинга
    # = для точного совпадения, чтобы не перехватывалось location /
    location = /stub_status {
        stub_status;
        allow 127.0.0.1;
        allow {{ monitoring_server_ip }};
        deny all;
    }
}
