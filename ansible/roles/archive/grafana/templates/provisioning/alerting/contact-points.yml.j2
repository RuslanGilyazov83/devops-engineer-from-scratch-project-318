apiVersion: 1

contactPoints:
  - orgId: 1
    name: "Telegram"
    receivers:
      - uid: "telegram-receiver"
        type: "telegram"
        settings:
          bottoken: "{{ telegram_bot_token }}"
          chatid: "{{ telegram_chat_id }}"
          # Отправлять уведомление и при восстановлении
        disableResolveMessage: false
