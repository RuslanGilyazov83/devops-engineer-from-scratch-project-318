# Promtail — отправка логов в Loki
# Лейблы: job, env, app, host для фильтрации в Grafana

server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /var/lib/promtail/positions.yaml

clients:
  - url: {{ loki_url }}/loki/api/v1/push

scrape_configs:

  # Логи Docker-контейнеров (приложение и др.)
  - job_name: docker
    static_configs:
      - targets:
          - localhost
        labels:
          job: docker
          env: prod
          app: bulletins
          host: {{ ansible_hostname | default(inventory_hostname) }}
          __path__: /var/lib/docker/containers/*/*-json.log
    pipeline_stages:
      # Docker json-file: {"log":"...","stream":"stdout","time":"..."}
      - json:
          expressions:
            output: log
            stream: stream
      - output:
          source: output

  # Nginx access — JSON-логи
  - job_name: nginx-access
    static_configs:
      - targets:
          - localhost
        labels:
          job: nginx
          logtype: access
          env: prod
          app: bulletins
          host: {{ ansible_hostname | default(inventory_hostname) }}
          __path__: /var/log/nginx/app-access.log
    pipeline_stages:
      # JSON-логи Nginx — парсим для LogQL (status, request_time, uri в structured metadata)
      - json:
          expressions:
            status: status
            request_time: request_time
            method: method
            uri: uri
            remote_addr: remote_addr

  # Nginx error
  - job_name: nginx-error
    static_configs:
      - targets:
          - localhost
        labels:
          job: nginx
          logtype: error
          env: prod
          app: bulletins
          host: {{ ansible_hostname | default(inventory_hostname) }}
          __path__: /var/log/nginx/app-error.log
